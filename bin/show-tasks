#!/bin/sh

if [ "$1" ]; then
	cd ~/"$1"-* 2>/dev/null || {
		echo "Level '$1' does not exist";
		exit 1;
	}
fi

while [ "$PWD" != / ] && ! [ -r README ]; do cd ..; done
[ -r README ] || {
 echo '❌ Tasks not found, are you in the correct directory?' >&2
 exit 1
}

cat README |
	if [ "$2" ]
	then
		level="$1"
		while [ "${level#0}" != "$level" ]; do level="${level#0}"; done
		awk -v RS= -v level="${level:-0}" -v task="$2" 'index($0,  "[" level "-" task "]")'
	else less -FRX
	fi
